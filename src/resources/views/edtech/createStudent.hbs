<div class="mt-4">
  <h3 class="mb-3">Create Student</h3>
  <form method="POST" action="/api/students">
    <div class="mb-3">
      <label for="parent_id" class="form-label">Parent ID</label>
      <input
        name="parent_id"
        type="text"
        class="form-control"
        id="parent_id"
        placeholder="Paste Parent ID here"
        required
      />
      <div class="form-text">Copy the ID from the Parent you just created.</div>
    </div>

    <div class="mb-3">
      <label for="studentName" class="form-label">Student Name</label>
      <input
        name="name"
        type="text"
        class="form-control"
        id="studentName"
        placeholder="Enter student name"
        required
      />
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <label for="dob" class="form-label">Date of Birth</label>
        <input name="dob" type="date" class="form-control" id="dob" />
      </div>
      <div class="col-md-6 mb-3">
        <label for="gender" class="form-label">Gender</label>
        <select name="gender" class="form-select" id="gender">
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <div class="mb-3">
      <label for="grade" class="form-label">Current Grade</label>
      <input
        name="current_grade"
        type="number"
        class="form-control"
        id="grade"
        placeholder="e.g. 10"
        min="1"
        max="12"
      />
    </div>

    <div class="mb-3">
      <button type="submit" class="btn btn-success">Create Student</button>
    </div>
  </form>
</div>