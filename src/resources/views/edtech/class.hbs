<div class="card mt-4 border-primary">
  <div class="card-header bg-primary text-white">
    <h4 class="mb-0">Quick Registration</h4>
  </div>
  <div class="card-body">
    <form id="registrationForm" method="POST" action="">
      <div class="row align-items-end">
        <div class="col-md-4 mb-3">
          <label class="form-label">Selected Class</label>
          <input
            type="text"
            id="classNameDisplay"
            class="form-control"
            placeholder="Click a class above"
            readonly
          />
        </div>
        <div class="col-md-5 mb-3">
          <label class="form-label">Student ID</label>
          <input
            name="student_id"
            type="text"
            class="form-control"
            placeholder="Paste Student ID here"
            required
          />
        </div>
        <div class="col-md-3 mb-3">
          <button type="submit" class="btn btn-primary w-100">Enroll Student</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  function selectClass(classId, className) { var form =
  document.getElementById('registrationForm'); var display =
  document.getElementById('classNameDisplay'); if (form && display) {
  form.action = '/api/classes/' + classId + '/register'; display.value =
  className; } }
</script>